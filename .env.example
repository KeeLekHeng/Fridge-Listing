# Database
# Runtime (pooled via PgBouncer — used by the app)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations (direct connection — used by prisma migrate)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Admin credentials (used by seed script on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
COOKIE_DOMAIN=localhost

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Object storage (Supabase Storage or any S3-compatible)
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_BASE_URL=

# Defaults (read by API at runtime)
DEFAULT_CAPACITY_LITRES=50
DEFAULT_RENT_PRICE=70
DEFAULT_DEPOSIT_PRICE=40
DEFAULT_DELIVERY_PRICE=15
